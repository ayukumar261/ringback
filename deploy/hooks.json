[
  {
    "id": "deploy",
    "execute-command": "/opt/ringback/deploy/deploy.sh",
    "command-working-directory": "/opt/ringback",
    "response-message": "Deploying...",
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": "{{ getenv \"RINGBACK_HOOK_SECRET\" }}",
        "parameter": {
          "source": "header",
          "name": "X-Hub-Signature-256"
        }
      }
    }
  }
]
